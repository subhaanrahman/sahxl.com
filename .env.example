# Copy to .env.local (git-ignored) and fill in real values.
# Vercel: set the same vars in the project's Environment Variables panel.

# ───────── Shopify (headless commerce) ─────────
# Get these from Shopify Admin → Apps → Develop apps → your custom app → Storefront API
SHOPIFY_STORE_DOMAIN="sahxl.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_API_VERSION="2024-10"

# Public-readable storefront token for client components (optional)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_URL="https://sahxl.myshopify.com/api/2024-10/graphql.json"

# ───────── Klaviyo (email capture + flows) ─────────
# Account → Settings → API Keys
KLAVIYO_PRIVATE_API_KEY=""
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=""
# Optional: list ID to subscribe the newsletter form to
KLAVIYO_NEWSLETTER_LIST_ID=""
# Optional: list ID for VIP showroom gate
KLAVIYO_VIP_LIST_ID=""

# ───────── VIP session signing ─────────
# 32+ char random secret. Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
VIP_SESSION_SECRET=""

# ───────── Site ─────────
NEXT_PUBLIC_SITE_URL="https://sahxl.com"
